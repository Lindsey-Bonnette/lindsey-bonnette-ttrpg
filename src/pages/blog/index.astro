---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base
	title={`Blog — ${SITE_TITLE}`}
	description="Design notes, quarterly updates, and behind-the-scenes writing on making indie tabletop RPGs by Lindsey Bonnette."
>
	<section class="container page-head">
		<p class="eyebrow">Writing & updates</p>
		<h1>Blog</h1>
		<p class="lead">
			Design notes, quarterly updates, and thoughts on writing, illustrating, and publishing
			tabletop adventures.
		</p>
	</section>

	<section class="container reveal reveal--stagger">
		<h2 class="sr-only">All posts</h2>
		<ul class="blog-list">
			{
				posts.map((post, i) => (
					<BlogCard
						index={i}
						href={`/blog/${post.id}`}
						title={post.data.title}
						pubDate={post.data.pubDate}
						description={post.data.description}
						heroImage={post.data.heroImage}
					/>
				))
			}
		</ul>
	</section>
</Base>

<style>
	.page-head {
		padding-top: var(--space-12);
		padding-bottom: var(--space-6);
		max-width: 760px;
	}
	.page-head h1 {
		margin: var(--space-2) 0 var(--space-4);
	}
	.lead {
		font-size: var(--fs-lead);
		color: var(--color-text-muted);
	}
	.blog-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--color-border);
		max-width: 820px;
	}
</style>
