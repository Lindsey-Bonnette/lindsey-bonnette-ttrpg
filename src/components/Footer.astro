---
import { EXTERNAL_LINKS, SITE_AUTHOR } from '../consts';
import SocialIcon from './SocialIcon.astro';

const year = new Date().getFullYear();
---

<footer>
	<div class="container footer-grid">
		<div class="footer-bio">
			<p class="footer-name">{SITE_AUTHOR} RPG Publishing</p>
			<p>Lindsey is a hobbyist RPG writer working out of the southern US.</p>
		</div>

		<nav class="footer-links" aria-label="Store and social">
			<p class="eyebrow">Find my work</p>
			<a href={EXTERNAL_LINKS.itch} target="_blank" rel="noopener"><SocialIcon name="itch" size={18} /> itch.io</a>
			<a href={EXTERNAL_LINKS.drivethru} target="_blank" rel="noopener"><SocialIcon name="drivethru" size={18} /> DriveThruRPG</a>
			<a href={EXTERNAL_LINKS.mastodon} target="_blank" rel="me noopener"><SocialIcon name="mastodon" size={18} /> Mastodon</a>
			<a href="/rss.xml"><SocialIcon name="rss" size={18} /> RSS Feed</a>
		</nav>
	</div>

	<div class="container footer-fine">
		<span>&copy; {year} {SITE_AUTHOR}. All rights reserved.</span>
		<span>Adventures for your table.</span>
	</div>
</footer>

<style>
	footer {
		flex-shrink: 0;
		background: var(--color-surface);
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-12);
		margin-top: var(--space-16);
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: var(--space-8);
		padding-bottom: var(--space-10);
	}
	.footer-name {
		font-family: var(--font-display);
		font-size: var(--fs-h3);
		margin-bottom: var(--space-3);
	}
	.footer-bio p:not(.footer-name) {
		color: var(--color-text-muted);
		font-size: var(--fs-small);
		max-width: 34ch;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}
	.footer-links .eyebrow {
		margin-bottom: var(--space-2);
	}
	.footer-links a {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--color-text-muted);
		text-decoration: none;
		font-size: var(--fs-small);
		width: fit-content;
	}
	.footer-links a:hover {
		color: var(--color-accent);
	}
	.footer-fine {
		display: flex;
		justify-content: space-between;
		gap: var(--space-4);
		padding-top: var(--space-5);
		padding-bottom: var(--space-8);
		border-top: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: var(--fs-tiny);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: var(--space-8);
		}
		.footer-fine {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
