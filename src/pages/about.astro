---
import Base from '../layouts/Base.astro';
import { SITE_TITLE, SITE_AUTHOR, EXTERNAL_LINKS } from '../consts';
---

<Base
	title={`About — ${SITE_TITLE}`}
	description={`${SITE_AUTHOR} is a hobbyist tabletop RPG writer from the southern US, self-publishing indie adventures since 2021.`}
>
	<section class="container about">
		<p class="eyebrow">About</p>
		<h1>Lindsey Bonnette</h1>

		<div class="prose">
			<p class="lead">
				Lindsey Bonnette is a hobbyist RPG writer working out of the Southern US.
			</p>
			<p>
				I grew up in a small town in Mississippi, so I didn't get into Tabletop RPGs until I was
				in college. I played and ran my first games in around 2014 and have been in love with the
				hobby ever since. In May of 2021 I released my first self published Dungeons and Dragon's
				adventure, and while that project could still use some editing, that success has powered me
				through several projects since.
			</p>
			<p>
				All my work is available through Itch.io or DrivethruRPG.
			</p>

			<h2>Where to find my work</h2>
			<ul class="links">
				<li><a href={EXTERNAL_LINKS.itch} target="_blank" rel="noopener">itch.io</a> — pay-what-you-want and free releases</li>
				<li><a href={EXTERNAL_LINKS.drivethru} target="_blank" rel="noopener">DriveThruRPG</a> — PDFs and print-on-demand</li>
				<li><a href={EXTERNAL_LINKS.mastodon} target="_blank" rel="me noopener">Mastodon (@LindseyBonnette@dice.camp)</a> — updates & behind-the-scenes</li>
			</ul>

			<p class="cta-row">
				<a class="btn btn-primary" href="/projects">Explore the projects</a>
			</p>
		</div>
	</section>
</Base>

<style>
	.about {
		padding-top: var(--space-12);
		max-width: 760px;
	}
	.about h1 {
		margin: var(--space-2) 0 var(--space-6);
	}
	.prose {
		margin: 0;
	}
	.lead {
		font-size: var(--fs-lead);
		color: var(--color-text-muted);
	}
	.links {
		list-style: none;
		padding: 0;
	}
	.links li {
		padding: var(--space-2) 0;
		border-bottom: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: var(--fs-small);
	}
	.cta-row {
		margin-top: var(--space-8);
	}
</style>
