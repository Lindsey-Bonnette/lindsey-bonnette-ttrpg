---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, updatedDate, heroImage, slug } = Astro.props;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: { '@type': 'Person', name: SITE_AUTHOR },
};
---

<Base title={`${title} — ${SITE_TITLE}`} description={description} image={`/og/${slug}.png`} imageAlt={title} type="article" jsonLd={jsonLd}>
	<article class="post">
		<header class="post-head container">
			<a class="back" href="/blog">← All posts</a>
			<p class="eyebrow post-date">
				<FormattedDate date={pubDate} />
				{updatedDate && <span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>}
			</p>
			<h1>{title}</h1>
		</header>

		{
			heroImage && (
				<div class="hero container">
					<Image src={heroImage} alt={`Illustration for ${title}`} widths={[720, 1200]} sizes="(max-width: 820px) 100vw, 800px" />
				</div>
			)
		}

		<div class="prose container-prose">
			<slot />
		</div>
	</article>
</Base>

<style>
	.post-head {
		padding-top: var(--space-8);
		max-width: 820px;
	}
	.back {
		display: inline-block;
		font-size: var(--fs-small);
		color: var(--color-text-muted);
		text-decoration: none;
		margin-bottom: var(--space-6);
	}
	.back:hover {
		color: var(--color-accent);
	}
	.post-date {
		color: var(--color-text-muted);
		margin-bottom: var(--space-3);
	}
	.post-head h1 {
		margin: 0;
	}
	.hero {
		margin: var(--space-8) auto;
		max-width: 900px;
	}
	.hero :global(img) {
		width: 100%;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		box-shadow:
			0 16px 40px rgba(0, 0, 0, 0.45),
			0 0 40px color-mix(in srgb, var(--color-accent) 10%, transparent);
	}
	.container-prose {
		max-width: var(--container-prose);
		margin-inline: auto;
		padding-inline: var(--gutter);
	}
	.prose {
		padding-top: var(--space-4);
		padding-bottom: var(--space-10);
	}
</style>
