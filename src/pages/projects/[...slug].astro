---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import TagGlyph from '../../components/TagGlyph.astro';
import { resolveTags } from '../../lib/tags';
import { SITE_TITLE, SITE_AUTHOR } from '../../consts';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

const project = Astro.props;
const { Content } = await render(project);
const d = project.data;
const tags = await resolveTags(d.tags);

const jsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: d.title,
	description: d.description,
	brand: { '@type': 'Brand', name: `${SITE_AUTHOR} RPG Publishing` },
};
if (d.itchUrl || d.drivethruUrl) {
	jsonLd.offers = [d.itchUrl, d.drivethruUrl].filter(Boolean).map((url) => ({
		'@type': 'Offer',
		url,
		availability: 'https://schema.org/InStock',
	}));
}
---

<Base title={`${d.title} — ${SITE_TITLE}`} description={d.description} image={`/og/${project.id}.png`} imageAlt={`${d.title} — cover art`} type="website" jsonLd={jsonLd}>
	<article class="container project">
		<a class="back" href="/projects">← All projects</a>
		<div class="layout">
			<div class="cover-col">
				{
					d.cover && (
						<Image class="cover" src={d.cover} alt={`Cover art for ${d.title}`} widths={[400, 700]} sizes="(max-width: 900px) 100vw, 400px" loading="eager" fetchpriority="high" />
					)
				}
			</div>

			<div class="info-col">
				{
					tags.length > 0 && (
						<div class="tags">
							{tags.map((t) => (
								<a class="tag" href={`/projects?tag=${t.slug}`} rel="nofollow">
									<TagGlyph slug={t.slug} />
									{t.label}
								</a>
							))}
						</div>
					)
				}
				<h1>{d.title}</h1>
				{d.tagline && <p class="tagline">{d.tagline}</p>}
				{d.price && <p class="price">{d.price}</p>}

				<div class="buy">
					{
						d.itchUrl && (
							<a class="btn btn-primary" href={d.itchUrl} target="_blank" rel="noopener">
								Get it on itch.io
							</a>
						)
					}
					{
						d.drivethruUrl && (
							<a class="btn btn-secondary" href={d.drivethruUrl} target="_blank" rel="noopener">
								DriveThruRPG
							</a>
						)
					}
				</div>

				<div class="prose description">
					<Content />
				</div>
			</div>
		</div>
	</article>
</Base>

<style>
	.project {
		padding-top: var(--space-8);
	}
	.back {
		display: inline-block;
		font-size: var(--fs-small);
		color: var(--color-text-muted);
		text-decoration: none;
		margin-bottom: var(--space-6);
	}
	.back:hover {
		color: var(--color-accent);
	}
	.layout {
		display: grid;
		grid-template-columns: 380px 1fr;
		gap: var(--space-10);
		align-items: start;
	}
	.cover-col {
		position: sticky;
		top: 88px;
	}
	.cover {
		width: 100%;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		box-shadow:
			0 18px 40px rgba(0, 0, 0, 0.5),
			0 0 44px color-mix(in srgb, var(--color-accent) 15%, transparent);
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-4);
	}
	.info-col h1 {
		margin: 0 0 var(--space-3);
	}
	.tagline {
		font-size: var(--fs-lead);
		color: var(--color-text-muted);
		margin-bottom: var(--space-4);
	}
	.price {
		font-family: var(--font-mono);
		color: var(--color-accent);
		font-size: var(--fs-small);
		margin-bottom: var(--space-5);
	}
	.buy {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--color-border);
	}
	.description {
		max-width: none;
		margin: 0;
	}
	@media (max-width: 900px) {
		.layout {
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}
		.cover-col {
			position: static;
			max-width: 340px;
		}
	}
</style>
