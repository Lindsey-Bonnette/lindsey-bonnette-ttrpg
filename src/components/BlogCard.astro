---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import type { ImageMetadata } from 'astro';
import { revealDelay } from '../lib/reveal';

interface Props {
	href: string;
	title: string;
	pubDate: Date;
	description?: string;
	heroImage?: ImageMetadata;
	/** Position in its list — drives the staggered reveal delay. */
	index?: number;
}
const { href, title, pubDate, description, heroImage, index = 0 } = Astro.props;
const reveal = revealDelay(index);
---

<li class="card" style={`--reveal-delay:${reveal}`}>
	<a href={href} class="card-link">
		{
			heroImage && (
				<div class="thumb">
					<Image src={heroImage} alt={`Illustration for ${title}`} widths={[200, 400]} sizes="200px" />
				</div>
			)
		}
		<div class="body">
			<p class="eyebrow"><FormattedDate date={pubDate} /></p>
			<h3>{title}</h3>
			{description && <p class="excerpt">{description}</p>}
		</div>
	</a>
</li>

<style>
	.card {
		position: relative;
		isolation: isolate;
		list-style: none;
		border-bottom: 1px solid var(--color-border);
	}
	/* Warm amber wash on hover — the row-card counterpart to the project
	   card's lamplight, sitting behind the content. */
	.card::before {
		content: "";
		position: absolute;
		inset: 0 calc(var(--gutter) * -0.5);
		z-index: -1;
		border-radius: var(--radius);
		background: linear-gradient(
			90deg,
			color-mix(in srgb, var(--color-accent) 9%, transparent),
			transparent 55%
		);
		opacity: 0;
		transition: opacity var(--transition);
	}
	.card:hover::before {
		opacity: 1;
	}
	.card-link {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: var(--space-5);
		padding: var(--space-6) 0;
		text-decoration: none;
		color: inherit;
	}
	.thumb {
		aspect-ratio: 3 / 2;
		overflow: hidden;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-border);
		background: var(--color-surface-2);
		transition: border-color var(--transition);
	}
	.card:hover .thumb {
		border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition:
			transform 300ms ease,
			filter 300ms ease;
	}
	.card:hover .thumb :global(img) {
		transform: scale(1.05);
		filter: brightness(1.05);
	}
	.body {
		min-width: 0;
	}
	.eyebrow {
		margin-bottom: var(--space-2);
		color: var(--color-text-muted);
	}
	.card h3 {
		margin: 0 0 var(--space-2);
		transition: color var(--transition);
	}
	.card:hover h3 {
		color: var(--color-accent);
	}
	.excerpt {
		color: var(--color-text-muted);
		font-size: var(--fs-small);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	@media (max-width: 640px) {
		.card-link {
			grid-template-columns: 1fr;
		}
		.thumb {
			max-width: 100%;
		}
	}
</style>
